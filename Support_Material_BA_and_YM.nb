Cell[BoxData[
 RowBox[{
  StyleBox[" ",
   FontSize->14], 
  StyleBox[
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Define", " ", "Psi", " ", "matrix"}], ",", " ", 
     RowBox[{"and", " ", "Reduce", " ", "Psi", " ", "matrix"}]}], "*)"}],
   FontSize->14], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"defPsi", "[", "N_", "]"}], ":=", 
     RowBox[{
      RowBox[{"defPsi", "[", "N", "]"}], "=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"i", ",", "j"}], "}"}], ",", "\n", 
        RowBox[{
         RowBox[{"Psi", "=", 
          RowBox[{"{", "}"}]}], ";", "\n", 
         RowBox[{"row", "=", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{
            RowBox[{"{", "}"}], ",", "N"}], "]"}]}], ";", "\n", 
         RowBox[{"row2", "=", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{
            RowBox[{"{", "}"}], ",", "N"}], "]"}]}], ";", "\n", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"i", "=", "1"}], ",", " ", 
           RowBox[{"i", "<=", " ", "N"}], ",", 
           RowBox[{"i", "++"}], ",", "\n", "\t", 
           RowBox[{
            RowBox[{"For", "[", 
             RowBox[{
              RowBox[{"j", "=", "1"}], ",", " ", 
              RowBox[{"j", "<=", " ", "N"}], ",", " ", 
              RowBox[{"j", "++"}], ",", "\n", "\t\t", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"i", "!=", "j"}], ",", "\n", "\t\t\t", 
                 RowBox[{
                  RowBox[{"row", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "=", 
                  RowBox[{"Append", "[", 
                   RowBox[{
                    RowBox[{"row", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], ",", 
                    RowBox[{
                    RowBox[{"ss", "[", 
                    RowBox[{
                    RowBox[{"{", "i", "}"}], ",", 
                    RowBox[{"{", "j", "}"}]}], "]"}], "/", 
