Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"(*", 
    RowBox[{"Define", " ", "Pfaffian"}], "*)"}],
   FontSize->14], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"drop", "[", 
       RowBox[{"m_", ",", "parts__List"}], "]"}], "/;", 
      RowBox[{
       RowBox[{"Length", "[", 
        RowBox[{"{", "parts", "}"}], "]"}], "\[LessEqual]", 
       RowBox[{"ArrayDepth", "[", "m", "]"}]}]}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"m", "[", 
         RowBox[{"[", "##1", "]"}], "]"}], "&"}], ")"}], "@@", 
      RowBox[{"MapThread", "[", 
       RowBox[{"Complement", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{"Dimensions", "[", 
            RowBox[{"m", ",", 
             RowBox[{"Length", "[", 
              RowBox[{"{", "parts", "}"}], "]"}]}], "]"}], "]"}], ",", 
          RowBox[{"{", "parts", "}"}]}], "}"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"pf", "[", "matrix_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Dimensions", "[", "matrix", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], "===", "2"}], ",", 
       RowBox[{"matrix", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "2"}], "]"}], "]"}], ",", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", "i"}], " ", 
          RowBox[{"matrix", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "i"}], "]"}], "]"}], " ", 
          RowBox[{"pf", "[", 
           RowBox[{"drop", "[", 
            RowBox[{"matrix", ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "i"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "i"}], "}"}]}], "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "2", ",", 
           RowBox[{
            RowBox[{"Dimensions", "[", "matrix", "]"}], "[", 
